import React from "react";
import { screen, waitFor, fireEvent } from "@testing-library/react";
import { Dashboard } from "@/components/Dashboard/Dashboard";
import * as api from "../../services/api";
import { render, setupTestEnvironment } from "../../test-utils";
import { AuthContext } from "../../contexts/AuthContext";

// Mock the API
jest.mock("../../services/api");
const mockApi = api as jest.Mocked<typeof api>;

// Mock Auth Context
const mockAuthContext = {
  restaurantId: "restaurant1",
  user: { id: "user1", email: "test@test.com" },
  login: jest.fn(),
  logout: jest.fn(),
  isAuthenticated: true,
};

// Create test wrapper with all providers
const TestWrapper = ({ children }: { children: React.ReactNode }) => (
  <AuthContext.Provider value={mockAuthContext}>
    {children}
  </AuthContext.Provider>
);

// Custom render function with providers
const renderWithProviders = (component: React.ReactElement) => {
  const restoreConsole = setupTestEnvironment();
  const result = render(component, { wrapper: TestWrapper });
  return { ...result, restoreConsole };
};

const mockDashboardData = {
  stats: {
    totalOrders: 156,
    totalRevenue: 2847.5,
    avgOrderValue: 18.25,
    pendingOrders: 12,
    activeOrders: 8,
    completedToday: 23,
  },
  recentOrders: [
    {
      id: "order1",
      customerName: "John Doe",
      status: "PENDING",
      total: 25.99,
      createdAt: "2024-01-01T12:00:00Z",
      items: [{ name: "Pizza", quantity: 1 }],
    },
    {
      id: "order2",
      customerName: "Jane Smith",
      status: "PREPARING",
      total: 18.5,
      createdAt: "2024-01-01T12:15:00Z",
      items: [{ name: "Burger", quantity: 1 }],
    },
  ],
  topDishes: [
    { name: "Pizza Margherita", orders: 45, revenue: 580.55 },
    { name: "Burger", orders: 32, revenue: 320.0 },
    { name: "Pasta Carbonara", orders: 28, revenue: 420.0 },
  ],
  revenueChart: {
    labels: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
    data: [120, 150, 180, 200, 220, 280, 190],
  },
};

beforeEach(() => {
  mockApi.getDashboardStats.mockResolvedValue(mockDashboardData);
});

afterEach(() => {
  jest.clearAllMocks();
});

describe("Dashboard Component", () => {
  it("renders loading state initially", () => {
    renderWithProviders(<Dashboard />);
    expect(screen.getByText("Loading dashboard...")).toBeInTheDocument();
  });

  it("renders dashboard stats after loading", async () => {
    renderWithProviders(<Dashboard />);

    await waitFor(() => {
      expect(screen.getByText("156")).toBeInTheDocument(); // Total Orders
    });

    expect(screen.getByText("€2,847.50")).toBeInTheDocument(); // Total Revenue
    expect(screen.getByText("€18.25")).toBeInTheDocument(); // Avg Order Value
    expect(screen.getByText("12")).toBeInTheDocument(); // Pending Orders
  });
});</content>
