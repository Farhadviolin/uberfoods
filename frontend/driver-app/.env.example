# UberFoods Driver App - Environment Variables

# API Configuration
# Backend API URL (ohne /api Suffix)
VITE_API_URL=http://localhost:3000

# WebSocket URL (für Development: Vite Proxy Port, für Production: API URL)
# Socket.IO benötigt HTTP/HTTPS URL, nicht WebSocket URL!
VITE_WS_URL=http://localhost:3004

# Application Name
VITE_APP_NAME=UberFoods Driver

# Authentication
# Überspringe Authentifizierung im Development (nur für Testing)
VITE_SKIP_AUTH=false

# Google Maps API
# API Key für Google Maps (Navigation, Geofencing)
# Erhältlich unter: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Development/Production Mode
# Wird automatisch von Vite gesetzt basierend auf npm run dev/build
# DEV=true für Development
# PROD=true für Production

# Optional: Sentry Error Tracking (wenn implementiert)
# VITE_SENTRY_DSN=your-sentry-dsn-here

# Optional: Analytics (wenn implementiert)
# VITE_ANALYTICS_ID=your-analytics-id-here
