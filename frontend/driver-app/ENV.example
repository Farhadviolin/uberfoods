# UberFoods Driver App – Beispielkonfiguration
# Kopiere diese Datei zu `.env` oder `.env.production` und fülle alle Werte aus.

# Basis-URLs (HTTPS in Produktion)
VITE_APP_NAME="UberFoods Driver"
VITE_API_URL="https://api.uberfoods.com"
VITE_WS_URL="https://api.uberfoods.com"

# Karten- und Routing-Services
VITE_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
VITE_TOMTOM_API_KEY=""
VITE_TRAFFIC_API_URL="https://traffic.uberfoods.com"
VITE_ALLOW_SIMULATION=false

# Monitoring & Error Tracking (optional, aber empfohlen)
VITE_SENTRY_DSN=""
VITE_LOGROCKET_APP_ID=""
VITE_ERROR_TRACKING_URL=""

# Sicherheits-Hinweis:
# Dieser Schalter ist ausschließlich für lokale Entwicklung gedacht.
# In Produktion MUSS er auf `false` bleiben oder entfernt werden.
VITE_SKIP_AUTH=false

