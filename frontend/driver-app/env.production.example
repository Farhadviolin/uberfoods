# ============================================
# UberFoods Driver App - Production Environment
# ============================================
# Kopiere diese Datei zu .env für Production

# ============================================
# CORE CONFIGURATION (ERFORDERLICH)
# ============================================

# App Name
VITE_APP_NAME=UberFoods Driver

# API URLs (Production)
# Variante 1: Separate API Domain
VITE_API_URL=https://api.yourdomain.com
VITE_WS_URL=wss://api.yourdomain.com
# Variante 2: Gleiche Domain (Reverse Proxy)
# VITE_API_URL=/api
# VITE_WS_URL=https://yourdomain.com

# ============================================
# GOOGLE MAPS (für GPS Tracking)
# ============================================
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# MONITORING
# ============================================
VITE_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
VITE_SENTRY_ENVIRONMENT=production

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_VOICE_ASSISTANT=false
VITE_ENABLE_SOCIAL_FEATURES=false
VITE_ENABLE_GAMIFICATION=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_GEOCODING=true
VITE_ENABLE_NOTIFICATIONS=true

# ============================================
# NOTES
# ============================================
# 1. Driver App braucht GPS-Berechtigung
# 2. WebSocket für Real-time Order Updates
# 3. Background Sync für Offline-Modus