# ============================================
# UberFoods Customer Web - Production Environment
# ============================================
# Kopiere diese Datei zu .env und fülle alle Werte aus.

# ============================================
# CORE CONFIGURATION (ERFORDERLICH)
# ============================================

# App Name
VITE_APP_NAME=UberFoods

# API URLs (Production)
# Variante 1: Separate API Domain
VITE_API_BASE_URL=https://api.yourdomain.com/api
VITE_WS_URL=wss://api.yourdomain.com
# Variante 2: Gleiche Domain (Reverse Proxy)
# VITE_API_BASE_URL=/api
# VITE_WS_URL=https://yourdomain.com

# ============================================
# GOOGLE MAPS API (P0 - KRITISCH)
# ============================================
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# PAYMENT (P0 - KRITISCH)
# ============================================
VITE_STRIPE_PUBLISHABLE_KEY=STRIPE_PUBLISHABLE_KEY_PLACEHOLDER

# Apple Pay
VITE_APPLE_MERCHANT_ID=merchant.yourdomain

# Google Pay
VITE_GOOGLE_MERCHANT_ID=your_google_pay_merchant_id

# ============================================
# SOCIAL AUTH (P1 - WICHTIG)
# ============================================
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here

# ============================================
# MONITORING (P1 - WICHTIG)
# ============================================
VITE_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
VITE_SENTRY_ENVIRONMENT=production

# ============================================
# ANALYTICS (P2 - OPTIONAL)
# ============================================
VITE_GA_ID=GA_MEASUREMENT_ID
VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
VITE_ENABLE_VOICE_ASSISTANT=false
VITE_ENABLE_SOCIAL_FEATURES=true
VITE_ENABLE_GAMIFICATION=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_GEOCODING=true
VITE_ENABLE_NOTIFICATIONS=true

# ============================================
# NOTES
# ============================================
# 1. ÄNDERE ALLE PLATZHALTER!
# 2. Verwende Production-Keys (nicht Test-Keys)
# 3. Vite-Variablen müssen mit VITE_ beginnen
# 4. Teste alle Features vor dem Deployment