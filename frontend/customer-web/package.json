{
  "name": "customer-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:e2e": "vite --mode e2e --host 127.0.0.1 --port 3102 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc --noEmit",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:esm": "NODE_OPTIONS=\"--experimental-vm-modules\" jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:with-servers": "powershell -ExecutionPolicy Bypass -File start-e2e-servers.ps1",
    "test:e2e:with-mocks": "VITE_E2E_MOCK=true powershell -ExecutionPolicy Bypass -File start-e2e-mock-servers.ps1",
    "test:e2e:deterministic": "run-e2e-deterministic.cmd",
    "test:e2e:full-lifecycle": "playwright test full-order-lifecycle.spec.ts",
    "test:e2e:full-platform": "playwright test -c playwright.full-platform.config.ts",
    "test:e2e:debug": "playwright test --debug full-order-lifecycle.spec.ts",
    "test:setup-auth": "node scripts/setup-auth.js",
    "test:e2e:isolated": "RUN_ID=$(date +%s)_${RANDOM} playwright test",
    "test:e2e:full-with-auth": "npm run test:setup-auth && npm run test:e2e:full-lifecycle",
    "test:e2e:stability": "node run-stability-test.js",
    "test:e2e:targeted": "playwright test api-validation.spec.ts",
    "test:e2e:validation": "npm run test:e2e:targeted && npm run test:e2e:stability",
    "e2e:gate:a": "playwright test --project=chromium e2e/auth.spec.ts e2e/restaurants.spec.ts e2e/menu-ordering.spec.ts",
    "e2e:gate:b": "playwright test --project=full-lifecycle e2e/full-order-lifecycle.spec.ts e2e/order-tracking.spec.ts",
    "setup:validate-env": "node scripts/validate-env.js",
    "check:partner-endpoint": "BACKEND_URL=${BACKEND_URL:-http://localhost:3000/api} bash scripts/check-partner-endpoint.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-google-maps/api": "^2.19.3",
    "@sentry/react": "^10.27.0",
    "@stripe/react-stripe-js": "^2.9.0",
    "@stripe/stripe-js": "^2.4.0",
    "@tanstack/react-query": "^5.90.8",
    "axios": "^1.6.2",
    "chart.js": "^4.4.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.23.24",
    "i18next": "^25.6.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "lodash-es": "^4.17.21",
    "lucide-react": "0.562.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.66.0",
    "react-i18next": "^16.3.3",
    "react-router-dom": "^6.20.0",
    "react-window": "^1.8.10",
    "socket.io-client": "^4.8.1",
    "terser": "^5.44.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "overrides": {
    "glob": "^10.3.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.0.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/google.maps": "^3.55.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.1.0",
    "workbox-window": "^7.3.0"
  }
}
