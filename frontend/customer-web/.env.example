# ============================================
# UberFoods Customer Web - Production Environment
# ============================================

# ==================== API CONFIGURATION ====================
# Backend API Base URL (ohne trailing slash; Customer Web hängt intern /api an)
# Production: https://api.uberfoods.com/api
# Development: http://localhost:3000/api
VITE_API_BASE_URL=https://api.uberfoods.com/api

# WebSocket URL (für Real-time Updates)
# Production: wss://api.uberfoods.com (oder https://api.uberfoods.com - Socket.IO macht Upgrade)
# Development: http://localhost:3000
VITE_WS_URL=https://api.uberfoods.com

# ==================== APP CONFIGURATION ====================
# App Name (wird in der UI angezeigt)
VITE_APP_NAME=UberFoods

# ==================== GOOGLE MAPS ====================
# Google Maps API Key (für Karten, Geocoding, Directions)
# Erstelle API Key in Google Cloud Console
# Benötigte APIs: Maps JavaScript API, Geocoding API, Directions API, Distance Matrix API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ==================== STRIPE PAYMENT ====================
# Stripe Publishable Key (öffentlicher Key für Frontend)
# Format: STRIPE_PUBLISHABLE_KEY_PLACEHOLDER_... für Production, STRIPE_PUBLISHABLE_KEY_PLACEHOLDER_... für Testing
# Von Stripe Dashboard: Developers > API Keys
VITE_STRIPE_PUBLISHABLE_KEY=STRIPE_PUBLISHABLE_KEY_PLACEHOLDER

# ==================== WEB PUSH NOTIFICATIONS ====================
# VAPID Public Key (für Web Push Notifications)
# Muss mit Backend VAPID_PUBLIC_KEY übereinstimmen
# Generiere mit: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ==================== MONITORING (OPTIONAL) ====================
# Sentry DSN (für Error Tracking)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# LogRocket App ID (für Session Replay)
# VITE_LOGROCKET_APP_ID=your_logrocket_app_id

# ==================== NOTES ====================
# 1. Kopiere diese Datei zu .env und fülle alle Keys aus
# 2. NIE .env Datei in Git committen!
# 3. In Production: Verwende HTTPS URLs und Live Keys
# 4. Google Maps API Key: Aktiviere Billing in Google Cloud Console
# 5. Stripe: Verwende Live Keys nur in Production
# 6. VAPID Keys: Müssen mit Backend übereinstimmen
