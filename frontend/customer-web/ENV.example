# ============================================
# UberFoods Customer Web - Environment Variables
# ============================================
# Kopiere diese Datei zu `.env` oder `.env.production` und fülle alle Werte aus.

# ============================================
# CORE CONFIGURATION (ERFORDERLICH)
# ============================================

# App Name
VITE_APP_NAME=UberFoods

# API URLs
# Development
VITE_API_BASE_URL=http://localhost:3000/api
VITE_WS_URL=http://localhost:3000

# Production (uncomment für Production)
# VITE_API_BASE_URL=https://api.uberfoods.com/api
# VITE_WS_URL=wss://api.uberfoods.com

# ============================================
# GOOGLE MAPS API (P0 - KRITISCH)
# ============================================
# Verwende den gleichen API Key wie im Backend
# Stelle sicher, dass "Maps JavaScript API" aktiviert ist

VITE_GOOGLE_MAPS_API_KEY=AIzaSyYourGoogleMapsAPIKeyHere

# ============================================
# SOCIAL AUTH (P1 - WICHTIG)
# ============================================
# Google OAuth 2.0 Client ID (für Social Login)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Facebook App ID (für Social Login)
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here

# ============================================
# PAYMENT (P0 - KRITISCH)
# ============================================
# Stripe Publishable Key
VITE_STRIPE_PUBLISHABLE_KEY=STRIPE_PUBLISHABLE_KEY_PLACEHOLDER

# Apple Pay Merchant ID
VITE_APPLE_MERCHANT_ID=merchant.uberfoods

# Google Pay Merchant ID
VITE_GOOGLE_MERCHANT_ID=123456789

# ============================================
# PUSH NOTIFICATIONS (P1 - WICHTIG)
# ============================================
# VAPID Public Key (für Web Push)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ============================================
# ERROR TRACKING & MONITORING (P1 - WICHTIG)
# ============================================
# Erstelle ein Sentry Account unter: https://sentry.io
# Verwende den gleichen DSN wie im Backend (oder separaten Frontend DSN)

VITE_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
VITE_SENTRY_ENVIRONMENT=development

# Alternative: LogRocket
# VITE_LOGROCKET_APP_ID=your_logrocket_app_id

# ============================================
# ANALYTICS (P2 - OPTIONAL)
# ============================================

# Google Analytics
# VITE_GA_ID=G-XXXXXXXXXX

# Plausible Analytics (Privacy-friendly Alternative)
# VITE_PLAUSIBLE_DOMAIN=uberfoods.com

# ============================================
# FEATURE FLAGS (Optional)
# ============================================

# Enable/Disable Features (Default: aus; nur aktivieren, wenn Backend bereit)
VITE_ENABLE_VOICE_ASSISTANT=false
VITE_ENABLE_SOCIAL_FEATURES=false
VITE_ENABLE_GAMIFICATION=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_GEOCODING=false
VITE_ENABLE_NOTIFICATIONS=false

# ============================================
# SECURITY
# ============================================

# Development Only - NIE in Production!
# VITE_SKIP_AUTH=false

# ============================================
# NOTES
# ============================================
# 1. ÄNDERE ALLE PLACEHOLDER-WERTE!
# 2. Vite-Variablen müssen mit VITE_ beginnen
# 3. Verwende NIE Production-Keys in Development
# 4. Setze entsprechende API Restrictions in Google Cloud Console

