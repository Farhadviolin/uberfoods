# ============================================
# UberFoods Admin Panel - Production Environment
# ============================================
# Kopiere diese Datei zu .env für Production

# ============================================
# CORE CONFIGURATION (ERFORDERLICH)
# ============================================

# App Name
VITE_APP_NAME=UberFoods Admin

# API URLs (Production)
# Variante 1: Separate API Domain
VITE_API_URL=https://api.yourdomain.com
VITE_WS_URL=wss://api.yourdomain.com
# Variante 2: Gleiche Domain (Reverse Proxy)
# VITE_API_URL=/api
# VITE_WS_URL=https://admin.yourdomain.com

# ============================================
# AUTHENTICATION
# ============================================
VITE_SKIP_AUTH=false
VITE_DEV_AUTH_TOKEN=

# ============================================
# MONITORING
# ============================================
VITE_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
VITE_SENTRY_ENVIRONMENT=production

# ============================================
# ANALYTICS (Optional)
# ============================================
VITE_GA_ID=GA_MEASUREMENT_ID

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_VOICE_ASSISTANT=false
VITE_ENABLE_SOCIAL_FEATURES=false
VITE_ENABLE_GAMIFICATION=false
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_GEOCODING=false
VITE_ENABLE_NOTIFICATIONS=true

# ============================================
# NOTES
# ============================================
# 1. ÄNDERE ALLE PLATZHALTER!
# 2. Admin Panel läuft auf eigenem Subdomain
# 3. Stelle sicher, dass CORS ALLOWED_ORIGINS admin.yourdomain.com enthält