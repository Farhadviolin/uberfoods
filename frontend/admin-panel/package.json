{
  "name": "admin-panel",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:fixed": "vite --host :: --port 3002 --strictPort",
    "dev:localhost": "vite --host localhost --port 3002",
    "dev:e2e": "vite --mode e2e --host 127.0.0.1 --port 3002",
    "setup": "./setup-localhost.sh",
    "start": "./start-localhost.sh",
    "build": "vite build",
    "preview": "vite preview",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 3002 --strictPort",
    "lint": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "type-check": "npm run typecheck",
    "typecheck": "node scripts/typecheck.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__",
    "test:components": "jest --testPathPattern=components/__tests__",
    "test:hooks": "jest --testPathPattern=hooks/__tests__",
    "test:utils": "jest --testPathPattern=utils/__tests__",
    "test:api": "ts-node scripts/test-api-endpoints.ts",
    "test:all": "npm run test:coverage && npm run test:api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "e2e:gate:a": "playwright test --project=chromium e2e/restaurant-management.spec.ts",
    "e2e:gate:b": "playwright test --project=chromium e2e/dashboard.spec.ts e2e/restaurant-management.spec.ts",
    "e2e:all": "playwright test"
  },
  "dependencies": {
    "@sentry/react": "^10.27.0",
    "@tanstack/react-query": "^5.90.9",
    "@tanstack/react-query-devtools": "^5.90.2",
    "axios": "^1.6.2",
    "chart.js": "^4.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.23.24",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "leaflet": "^1.9.4",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.560.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.68.0",
    "react-hotkeys-hook": "^5.2.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.10.0",
    "react-window": "^1.8.10",
    "recharts": "^3.5.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "babel-jest": "^30.2.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.3",
    "terser": "^5.44.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  },
  "overrides": {
    "archiver": "^7.0.1",
    "archiver-utils": "^5.0.2",
    "glob": "^10.3.10",
    "esbuild": "^0.27.1"
  }
}
