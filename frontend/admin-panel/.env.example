# ============================================
# UberFoods Admin Panel - Production Environment
# ============================================

# ==================== API CONFIGURATION ====================
# Backend API URL (OHNE trailing slash)
# Production: https://api.uberfoods.com
# Development: http://localhost:3000
VITE_API_URL=https://api.uberfoods.com

# WebSocket URL (für Real-time Updates)
# Production: wss://api.uberfoods.com (oder https://api.uberfoods.com - Socket.IO macht Upgrade)
# Development: http://localhost:3000
VITE_WS_URL=https://api.uberfoods.com

# ==================== APP CONFIGURATION ====================
# App Name (wird in der UI angezeigt)
VITE_APP_NAME=UberFoods Admin

# ==================== MONITORING (OPTIONAL) ====================
# Sentry DSN (für Error Tracking)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# LogRocket App ID (für Session Replay)
# VITE_LOGROCKET_APP_ID=your_logrocket_app_id

# ==================== NOTES ====================
# 1. Kopiere diese Datei zu .env und passe die URLs an
# 2. NIE .env Datei in Git committen!
# 3. In Production: Verwende HTTPS URLs
# 4. WebSocket URL muss HTTP/HTTPS sein, nicht ws:// oder wss://
#    (Socket.IO macht selbst das Upgrade zu WebSocket)
