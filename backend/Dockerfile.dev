# Alpine 3.16 has OpenSSL 1.1.x required by Prisma engine (3.17+ uses OpenSSL 3.x)
FROM node:20-alpine3.16

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY prisma ./prisma/

# Install dependencies with legacy peer deps to handle version conflicts
RUN NODE_OPTIONS="--max-old-space-size=4096" npm install --legacy-peer-deps

# Generate Prisma client
RUN npx prisma generate

# Copy source code
COPY . .

# Build the application (Full MVP stack)
RUN npm run build

# Expose port
EXPOSE 3000

# Default command - run Full stack for local MVP
CMD ["node", "dist/main.full.js"]
