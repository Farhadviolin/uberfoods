model WorkflowEvent {
  id            String   @id @default(cuid())
  type          String // Event type
  source        String // Event source
  data          Json // Event data
  correlationId String? // Correlation ID for tracking related events
  causationId   String? // Causation ID for event chains
  metadata      Json? // Additional metadata
  timestamp     DateTime @default(now())
  processed     Boolean  @default(false)

  @@index([type])
  @@index([correlationId])
  @@index([timestamp])
  @@index([processed])
  @@map("workflow_events")
}

model WorkflowInstance {
  id          String    @id @default(cuid())
  workflowId  String // Reference to workflow definition
  status      String    @default("running") // 'running', 'completed', 'failed', 'paused'
  currentStep String // Current step ID
  context     Json // Workflow context data
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([workflowId])
  @@index([status])
  @@index([startedAt])
  @@map("workflow_instances")
}

model WorkflowDefinition {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  steps       Json // Workflow steps definition
  version     String   @default("1.0")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([isActive])
  @@map("workflow_definitions")
}

model OrchestrationExecution {
  id         String   @id @default(cuid())
  ruleId     String // Reference to orchestration rule
  eventId    String // Reference to triggering event
  executedAt DateTime @default(now())
  success    Boolean  @default(true)
  error      String?
  rule       Json? // Store rule snapshot for audit
  event      Json? // Store event snapshot for audit

  @@index([ruleId])
  @@index([eventId])
  @@index([executedAt])
  @@index([success])
  @@map("orchestration_executions")
}

model EmergencyIncident {
  id            String    @id @default(cuid())
  type          String // 'medical', 'vehicle', 'security', 'technical', 'other'
  severity      String // 'low', 'medium', 'high', 'critical'
  description   String
  location      Json? // Location data with lat/lng
  reportedBy    String
  reportedFrom  String // Source app
  affectedUsers String[] // Array of affected user IDs
  workflowId    String?
  status        String    @default("active") // 'active', 'resolved', 'closed'
  resolution    String?
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@map("emergency_incidents")
}

model CrossAppSupportTicket {
  id                String    @id @default(cuid())
  category          String // 'order_issue', 'payment_problem', 'account_issue', 'technical_problem', 'general_inquiry'
  priority          String // 'LOW', 'MEDIUM', 'HIGH', 'URGENT'
  subject           String
  description       String
  customerId        String
  orderId           String?
  contactMethod     String // 'chat', 'email', 'phone', 'app'
  preferredLanguage String    @default("de")
  assignedTeam      String?
  assignedAgent     String?
  workflowId        String?
  status            String    @default("open") // 'open', 'assigned', 'in_progress', 'resolved', 'closed'
  resolution        String?
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([category])
  @@index([priority])
  @@index([status])
  @@index([customerId])
  @@index([assignedAgent])
  @@map("cross_app_support_tickets")
}

model AnalyticsReport {
  id          String    @id @default(cuid())
  type        String // 'performance', 'revenue', 'user_behavior', 'operational', 'predictive'
  timeRange   Json // { start: Date, end: Date }
  metrics     String[] // Array of metric names
  filters     Json? // Filter criteria
  data        Json // Report data
  recipients  String[] // Array of recipient IDs
  format      String    @default("dashboard") // 'dashboard', 'pdf', 'csv', 'email'
  status      String    @default("generating") // 'generating', 'completed', 'failed'
  generatedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([type])
  @@index([status])
  @@index([generatedAt])
  @@map("analytics_reports")
}

model CrossAppCustomerFeedback {
  id             String    @id @default(cuid())
  orderId        String
  customerId     String
  restaurantId   String
  driverId       String?
  rating         Json // { food: number, delivery: number, overall: number }
  comment        String?
  sentiment      String // 'positive', 'neutral', 'negative'
  analysis       Json? // AI analysis results
  requiresAction Boolean   @default(false)
  actionItems    String[] // Array of action item IDs
  status         String    @default("received") // 'received', 'reviewed', 'actioned', 'closed'
  reviewedAt     DateTime?
  reviewedBy     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([orderId])
  @@index([customerId])
  @@index([restaurantId])
  @@index([driverId])
  @@index([sentiment])
  @@index([status])
  @@map("cross_app_customer_feedback")
}

model QualityInvestigation {
  id                  String    @id @default(cuid())
  type                String // Type of quality issue
  severity            String // 'low', 'medium', 'high', 'critical'
  description         String
  relatedOrderId      String?
  relatedRestaurantId String?
  relatedDriverId     String?
  status              String    @default("investigating") // 'investigating', 'action_required', 'resolved', 'closed'
  assignedTo          String?
  findings            Json? // Investigation findings
  correctiveActions   String[] // Array of corrective action IDs
  resolution          String?
  resolvedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([assignedTo])
  @@map("quality_investigations")
}

// Offline Sync Models
model SyncState {
  id               String    @id @default(cuid())
  userId           String
  deviceId         String
  lastSyncTimestamp DateTime @default(now())
  syncVersion      Int       @default(1)
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([deviceId])
  @@index([lastSyncTimestamp])
  @@map("sync_states")
}

model SyncQueue {
  id          String   @id @default(cuid())
  userId      String
  deviceId    String
  table       String
  operation   String   // 'INSERT' | 'UPDATE' | 'DELETE'
  data        Json
  version     Int      @default(1)
  status      String   @default("pending") // 'pending' | 'processing' | 'completed' | 'failed'
  error       String?
  retryCount  Int      @default(0)
  maxRetries  Int      @default(3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  processedAt DateTime?

  @@index([userId, deviceId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("sync_queue")
}

model SyncConflict {
  id           String    @id @default(cuid())
  userId       String
  deviceId     String
  table        String
  localData    Json
  serverData   Json
  conflictType String    // 'version' | 'data' | 'deletion'
  resolution   String?   // 'local' | 'server' | 'merge'
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, deviceId])
  @@index([conflictType])
  @@index([resolution])
  @@index([resolvedAt])
  @@index([userId, deviceId, resolvedAt])
  @@map("sync_conflicts")
}

// ============================================
// Restaurant Locations (Multi-Location Support)
// ============================================

model RestaurantLocation {
  id              String    @id @default(cuid())
  restaurantId    String
  name            String
  address         String
  city            String
  postalCode      String
  country         String    @default("Österreich")
  phone           String
  email           String
  isActive        Boolean   @default(true)
  operatingHours  Json?
  managerId       String?
  managerName     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([isActive])
  @@map("restaurant_locations")
}

// ============================================
// Supplier Management
// ============================================

enum PaymentTerms {
  NET_30
  NET_60
  IMMEDIATE
}

enum SupplierOrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

model SupplierOrder {
  id           String               @id @default(cuid())
  supplierId   String
  restaurantId String
  orderDate    DateTime             @default(now())
  deliveryDate DateTime?
  status       SupplierOrderStatus  @default(PENDING)
  totalAmount  Float
  items        Json
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  supplier   Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([restaurantId])
  @@index([status])
  @@map("supplier_orders")
}

// ============================================
// Table & Reservation Management
// ============================================

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum TableShape {
  SQUARE
  ROUND
  RECTANGLE
}

enum ReservationStatus {
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
}

model RestaurantTable {
  id           String      @id @default(cuid())
  restaurantId String
  number       Int
  capacity     Int
  status       TableStatus @default(AVAILABLE)
  shape        TableShape  @default(SQUARE)
  location     Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@unique([restaurantId, number])
  @@index([restaurantId])
  @@index([status])
  @@map("restaurant_tables")
}

model Reservation {
  id              String             @id @default(cuid())
  restaurantId    String
  tableId         String?
  customerName    String
  customerPhone   String
  partySize       Int
  reservationTime DateTime
  status          ReservationStatus  @default(CONFIRMED)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table       RestaurantTable? @relation(fields: [tableId], references: [id])

  @@index([restaurantId])
  @@index([tableId])
  @@index([reservationTime])
  @@index([status])
  @@map("reservations")
}

// Advanced Subscription Management Tables
model GDPRRequest {
  id          String   @id @default(cuid())
  driverId    String
  type        GDPRRequestType
  reason      String?
  status      GDPRRequestStatus @default(PENDING)
  dataPackage Json? // For data portability
  requestedAt DateTime @default(now())
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([type])
  @@index([status])
  @@map("gdpr_requests")
}


model WinbackCampaignLog {
  id             String   @id @default(cuid())
  driverId       String
  campaignId     String
  discountCode   String?
  discountPercentage Float
  emailType      String // winback_offer, winback_reminder, etc.
  sentAt         DateTime @default(now())
  openedAt       DateTime?
  clickedAt      DateTime?
  convertedAt    DateTime?
  createdAt      DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([campaignId])
  @@index([sentAt])
  @@map("winback_campaign_logs")
}

model DiscountCode {
  id            String        @id @default(cuid())
  code          String        @unique
  type          String        @default("PERCENTAGE") // PERCENTAGE, FIXED
  value         Float
  validUntil    DateTime
  usageLimit    Int?
  usedCount     Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([code])
  @@index([validUntil])
  @@index([isActive])
  @@map("discount_codes")
}

model CustomerLifetimeValue {
  id              String   @id @default(cuid())
  driverId        String   @unique
  historicalValue Float    @default(0)
  predictedValue  Float    @default(0)
  totalValue      Float    @default(0)
  confidence      Float    @default(0) // 0-1 confidence score
  segments        Json? // RFM segmentation data
  lastCalculated  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([totalValue])
  @@index([lastCalculated])
  @@map("customer_lifetime_value")
}

model ChurnPrediction {
  id              String   @id @default(cuid())
  driverId        String   @unique
  churnProbability Float   @default(0) // 0-1 probability
  riskLevel       String   @default("LOW") // LOW, MEDIUM, HIGH
  predictedAt     DateTime
  factors         Json? // Contributing factors
  confidence      Float    @default(0) // 0-1 confidence score
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([churnProbability])
  @@index([riskLevel])
  @@index([predictedAt])
  @@map("churn_predictions")
}

model SubscriptionContract {
  id            String   @id @default(cuid())
  driverId      String
  subscriptionId String
  contractNumber String  @unique
  contractData  Json // Full contract data
  pdfUrl        String?
  signedAt      DateTime?
  expiresAt     DateTime?
  status        String   @default("DRAFT") // DRAFT, SIGNED, EXPIRED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  subscription DriverSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([subscriptionId])
  @@index([contractNumber])
  @@index([status])
  @@map("subscription_contracts")
}


