generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id                            String                       @id @default(cuid())
  name                          String?
  email                         String                       @unique
  password                      String
  firstName                     String?
  lastName                      String?
  phone                         String?
  address                       String?
  isActive                      Boolean                      @default(true)
  status                        String                       @default("ACTIVE")
  marketingConsent              Boolean                      @default(false)
  resetToken                    String?
  resetTokenExpiresAt           DateTime?
  socialAuthProvider            String? // 'google', 'facebook', 'apple'
  socialAuthId                  String? // Provider-spezifische ID
  socialAuthEmail               String? // Email vom Provider
  emailVerified                 Boolean                      @default(false)
  metadata                      Json? // UI preferences, settings, etc.
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  addresses                     Address[]
  achievements                  CustomerAchievement[]
  chefProfile                   CustomerChefProfile?
  favorites                     CustomerFavorite[]
  gamification                  CustomerGamification?
  loyalty                       CustomerLoyalty?
  giftCards                     GiftCard[]                   @relation("CustomerGiftCards")
  groupOrderItems               GroupOrderItem[]             @relation("GroupOrderItemCustomer")
  groupOrderMemberships         GroupOrderMember[]           @relation("GroupOrderMemberCustomer")
  groupOrdersHosted             GroupOrder[]                 @relation("GroupOrderHost")
  loyaltyPoints                 LoyaltyPointsHistory[]
  mealPlans                     MealPlan[]
  mealPlanTemplates             MealPlanTemplate[]
  orders                        Order[]
  paymentMethods                PaymentMethod[]
  receivedReferrals             Referral[]                   @relation("ReferralReferred")
  sentReferrals                 Referral[]                   @relation("ReferralReferrer")
  reviewLikes                   ReviewLike[]
  reviewReports                 ReviewReport[]
  reviewComments                ReviewComment[]
  reviewHelpfuls                ReviewHelpful[]
  reviews                       Review[]
  scheduledOrders               ScheduledOrder[]
  socialChallengeParticipations SocialChallengeParticipant[] @relation("CustomerSocialChallengeParticipants")
  socialComments                SocialComment[]
  socialFollows                 SocialFollow[]               @relation("SocialFollowFollower")
  followers                     SocialFollow[]               @relation("SocialFollowFollowing")
  socialLikes                   SocialLike[]
  socialPosts                   SocialPost[]
  socialShares                  SocialShare[]
  socialBookmarks               SocialBookmark[]
  socialHiddenPosts             SocialHiddenPost[]
  socialReports                 SocialReport[]
  resolvedReports               SocialReport[]               @relation("ReportResolvedBy")
  savedCarts                    SavedCart[]
  favoriteDishes                FavoriteDish[]
  restaurantAlerts              RestaurantAlert[]

  @@index([email])
  @@index([socialAuthId])
  @@index([socialAuthProvider])
  @@index([isActive])
  @@index([status])
  @@index([createdAt])
  @@index([isActive, createdAt])
  @@index([status, createdAt])
  @@index([name, email])
  @@map("customers")
}

model Restaurant {
  id                    String                @id @default(cuid())
  name                  String
  description           String?
  address               String
  phone                 String?
  email                 String                @unique
  imageUrl              String?
  password              String?
  mustChangePassword    Boolean               @default(true)
  welcomeEmailSent      Boolean               @default(false)
  welcomeEmailSentAt    DateTime?
  status                String                @default("OPEN")
  rating                Float                 @default(0)
  totalOrders           Int                   @default(0)
  avgPrepTime           Int                   @default(15)
  minOrderAmount        Float                 @default(0)
  deliveryFee           Float                 @default(2.5)
  freeDeliveryThreshold Float?
  location              Json?
  deliveryZones         Json?
  operatingHours        Json?
  estimatedDeliveryTime Int                   @default(30)
  cuisines              String[]              @default([])
  tags                  String[]              @default([])
  settings              Json?
  // Flexible Zusatzdaten
  metadata              Json?
  resetToken            String?
  resetTokenExpiresAt   DateTime?
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  favorites             CustomerFavorite[]
  restaurantAlerts      RestaurantAlert[]
  dishes                Dish[]
  giftCards             GiftCard[]            @relation("RestaurantGiftCards")
  groupOrders           GroupOrder[]
  legalPages            LegalPage[]
  loyaltyPrograms       LoyaltyProgram[]
  mealPlans             MealPlan[]
  orders                Order[]
  promotions            Promotion[]
  taxProfile            RestaurantTaxProfile?
  reviewReplies         ReviewReply[]
  reviews               Review[]
  scheduledOrders       ScheduledOrder[]
  socialChallenges      SocialChallenge[]
  socialPosts           SocialPost[]
  restaurantSocialPosts RestaurantSocialPost[]
  staff                 Staff[]
  inventoryItems        StockItem[]
  locations             RestaurantLocation[]
  supplierOrders        SupplierOrder[]
  tables                RestaurantTable[]
  reservations          Reservation[]

  @@index([isActive])
  @@index([status])
  @@index([createdAt])
  @@index([isActive, status])
  @@index([isActive, createdAt])
  @@map("restaurants")
}

model Driver {
  id                      String                    @id @default(cuid())
  name                    String
  email                   String                    @unique
  phone                   String?
  password                String?
  mustChangePassword      Boolean                   @default(true)
  welcomeEmailSent        Boolean                   @default(false)
  welcomeEmailSentAt      DateTime?
  isActive                Boolean                   @default(true)
  location                Json?
  avatarUrl               String?
  vehicleInfo             Json?
  rating                  Float                     @default(0)
  totalDeliveries         Int                       @default(0)
  currentStatus           String                    @default("OFFLINE")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  // Flexible Zusatzdaten
  metadata                Json?
  resetToken              String?
  resetTokenExpiresAt     DateTime?
  // Payouts / Banking
  stripeConnectAccountId  String?
  bankAccountVerified     Boolean                   @default(false)
  // Stripe integration for subscriptions
  stripeCustomerId        String?                   @unique
  commissionTransactions  CommissionTransaction[]
  shifts                  Shift[]
  schedules               DriverSchedule[]
  subscription            DriverSubscription?
  taxProfile              DriverTaxProfile?
  orders                  Order[]
  reviews                 Review[]
  // Additional relations for Driver App features
  orderNotes              OrderNote[]
  orderDelays             OrderDelay[]
  bulkOrderActions        BulkOrderAction[]
  routeOptimizations      RouteOptimization[]
  routeHistories          RouteHistory[]
  routeAlternatives       RouteAlternative[]
  performances            DriverPerformance[]
  performanceGoals        PerformanceGoal[]
  gamificationStats       GamificationStats?
  gamificationChallenges  GamificationAchievement[]
  gamificationQuests      GamificationQuest[]
  emergencyAlerts         EmergencyAlert[]
  safetyIncidents         SafetyIncident[]
  safetyScore             SafetyScore?
  emergencyContacts       EmergencyContact[]
  expenses                DriverExpense[]
  financialProjections    FinancialProjection[]
  taxDeductions           TaxDeduction[]
  // Relations for advanced subscription features
  gdprRequests            GDPRRequest[]
  winbackCampaignLogs     WinbackCampaignLog[]
  lifetimeValue           CustomerLifetimeValue?
  churnPrediction         ChurnPrediction?
  subscriptionContracts   SubscriptionContract[]
  financialBonuses        FinancialBonus[]
  financialBudgets        FinancialBudget[]
  subscriptionFeatures    SubscriptionFeature[]
  subscriptionUsage       SubscriptionUsage[]
  subscriptionAnalytics   SubscriptionAnalytics[]
  metaGlassesSessions     MetaGlassesSession[]
  voiceCommands           VoiceCommand[]
  qrScans                 QRScan[]
  driverReferralsSent     DriverReferral[]          @relation("DriverReferrer")
  driverReferralsReceived DriverReferral[]          @relation("DriverReferred")
  emergencyLogs           EmergencyLog[]
  favoriteOrders          FavoriteOrder[]
  // Fleet Management Relations
  fleetZoneId             String?
  fleetZone               FleetZone?                @relation(fields: [fleetZoneId], references: [id])
  fleetShifts             FleetShift[]
  fleetRoutes             FleetRoute[]
  vehicle                 Vehicle?
  fleetIncidents          FleetIncident[]

  // Performance Tracking Relations
  performanceAlerts  PerformanceAlert[]
  performanceRewards PerformanceReward[]

  // Audit Events
  auditEvents       DriverAuditEvent[]

  // ML Assignment Relations
  assignmentLogs AssignmentLog[]

  @@index([isActive])
  @@index([currentStatus])
  @@index([email])
  @@index([rating])
  @@index([isActive, currentStatus, createdAt])
  @@index([currentStatus, rating])
  @@index([name, email])
  @@map("drivers")
}

model PartnerApplication {
  id               String   @id @default(cuid())
  role             String
  contactName      String
  contactEmail     String
  contactPhone     String
  contactCity      String?
  contactCountry   String?
  notes            String?
  consentTerms     Boolean  @default(false)
  consentMarketing Boolean  @default(false)
  driverInfo       Json?
  restaurantInfo   Json?
  status           String   @default("pending")
  createdAt        DateTime @default(now())

  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@map("partner_applications")
}

model DriverAuditEvent {
  id             String   @id @default(cuid())
  driverId       String
  action         String
  orderId        String?
  location       Json?
  deviceId       String?
  appVersion     String?
  networkType    String?
  battery        Float?
  region         String?
  isOfflineSync  Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())

  driver         Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, createdAt])
  @@index([driverId, action, createdAt])
  @@index([orderId, createdAt])
  @@index([region, createdAt])
  @@map("driver_audit_events")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dishes    Dish[]

  @@map("categories")
}

model Dish {
  id               String           @id @default(cuid())
  name             String
  description      String?
  price            Float
  imageUrl         String?
  category         String
  isAvailable      Boolean          @default(true)
  tags             String[]         @default([])
  calories         Int?
  nutrition        Json?
  prepTime         Int?
  restaurantId     String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  // Neue Felder für Category-Relation
  isActive         Boolean          @default(true)
  categoryId       String?
  categoryRelation Category?        @relation(fields: [categoryId], references: [id])
  nutritionFacts   DishNutrition?
  restaurant       Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  // Metadata field for ingredients and steps
  metadata         Json?
  groupOrderItems  GroupOrderItem[] @relation("GroupOrderItemDish")
  items            OrderItem[]
  socialPosts      SocialPost[]
  favorites        FavoriteDish[]

  @@index([restaurantId, isAvailable])
  @@index([category])
  @@index([isAvailable])
  @@index([categoryId])
  @@map("dishes")
}

model Order {
  id                    String                 @id @default(cuid())
  customerId            String
  restaurantId          String
  driverId              String?
  status                String                 @default("PENDING")
  totalAmount           Float
  deliveryFee           Float                  @default(0)
  taxAmount             Float                  @default(0)
  notes                 String?
  cancelReason          String?
  discountAmount        Float                  @default(0)
  paymentStatus         PaymentStatus          @default(PENDING)
  version               Int                    @default(1)
  address               String?
  phone                 String?
  customerLocation      Json?
  scheduledFor          DateTime?
  estimatedDeliveryTime Int?
  deliveredAt           DateTime?
  canCancelUntil        DateTime?
  promotionId           String?
  priority              String?
  route                 Json?
  metadata              Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  actualDeliveryTime    DateTime?
  subtotal              Float                  @default(0)
  // Neue Felder für Finanzen und Lieferung
  tax                   Float                  @default(0)
  tip                   Float                  @default(0)
  deliveryAddress       String?
  deliveryInstructions  String?
  paymentMethod         String?
  transactionId         String?
  chatMessages          ChatMessage[]
  commissionTransaction CommissionTransaction?
  loyaltyHistory        LoyaltyPointsHistory[]
  items                 OrderItem[]
  customer              Customer               @relation(fields: [customerId], references: [id])
  driver                Driver?                @relation(fields: [driverId], references: [id])
  promotion             Promotion?             @relation(fields: [promotionId], references: [id])
  restaurant            Restaurant             @relation(fields: [restaurantId], references: [id])
  payments              Payment[]
  reviews               Review[]
  socialPosts           SocialPost[]
  // Additional relations for Driver App features
  orderNotes            OrderNote[]
  orderDelays           OrderDelay[]
  favoriteOrders        FavoriteOrder[]
  fleetRoutes           FleetRoute[] // Many-to-many relation with FleetRoute
  assignmentLogs        AssignmentLog[]

  @@index([customerId])
  @@index([restaurantId])
  @@index([driverId])
  @@index([promotionId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([restaurantId, status])
  @@index([customerId, createdAt])
  @@index([status, createdAt, restaurantId])
  @@index([driverId, status])
  @@index([status, deliveredAt])
  // Keyset Pagination Indexes für skalierbare Cursor-basierte Pagination
  @@index([status, createdAt, id])
  @@index([restaurantId, status, createdAt, id])
  @@index([customerId, createdAt, id])
  @@map("orders")
}

model OrderItem {
  id                  String  @id @default(cuid())
  orderId             String
  dishId              String
  quantity            Int
  price               Float
  modifications       Json?
  specialInstructions String?
  dish                Dish    @relation(fields: [dishId], references: [id])
  order               Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  label      String?
  street     String
  city       String
  postalCode String
  country    String   @default("Austria")
  latitude   Float?
  longitude  Float?
  notes      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([customerId, isDefault])
  @@map("addresses")
}

model CustomerFavorite {
  id           String     @id @default(cuid())
  customerId   String
  restaurantId String
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([customerId, restaurantId])
  @@map("customer_favorites")
}

model RestaurantAlert {
  id           String     @id @default(cuid())
  customerId   String
  restaurantId String
  alertType    String     @default("OPENED") // OPENED, PROMOTION, NEW_DISH
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([customerId, restaurantId, alertType])
  @@index([customerId])
  @@index([restaurantId])
  @@index([isActive])
  @@map("restaurant_alerts")
}

model PaymentMethod {
  id              String            @id @default(cuid())
  customerId      String
  type            PaymentMethodType
  last4           String?
  brand           String?
  iban            String?
  bic             String?
  mandateId       String?
  isDefault       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  expiryMonth     Int?
  expiryYear      Int?
  paymentMethodId String?
  customer        Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  payments        Payment[]

  @@index([customerId])
  @@index([customerId, paymentMethodId])
  @@map("payment_methods")
}

model Payment {
  id                String         @id @default(cuid())
  orderId           String
  customerId        String
  paymentMethodId   String?
  amount            Float
  currency          String         @default("EUR")
  status            PaymentStatus  @default(PENDING)
  paymentIntentId   String?
  transactionId     String?
  errorMessage      String?
  paymentMethodType String?
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod     PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([customerId, status])
  @@map("payments")
}

model DriverTaxProfile {
  id                 String             @id @default(cuid())
  driverId           String             @unique
  taxId              String?
  finanzamtId        String?
  finanzamtStatus    FinanzamtStatus    @default(PENDING)
  autoReportEnabled  Boolean            @default(true)
  autoPayoutEnabled  Boolean            @default(true)
  reportingFrequency ReportingFrequency @default(MONTHLY)
  iban               String?
  bic                String?
  lastReportDate     DateTime?
  lastPayoutDate     DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  driver             Driver             @relation(fields: [driverId], references: [id], onDelete: Cascade)
  payouts            Payout[]
  taxReports         TaxReport[]

  @@index([driverId])
  @@index([finanzamtStatus])
  @@map("driver_tax_profiles")
}

model RestaurantTaxProfile {
  id                 String             @id @default(cuid())
  restaurantId       String             @unique
  taxId              String?
  ustId              String?
  finanzamtId        String?
  finanzamtStatus    FinanzamtStatus    @default(PENDING)
  autoReportEnabled  Boolean            @default(true)
  autoPayoutEnabled  Boolean            @default(true)
  reportingFrequency ReportingFrequency @default(MONTHLY)
  tseEnabled         Boolean            @default(false)
  tseSerialNumber    String?
  iban               String?
  bic                String?
  lastReportDate     DateTime?
  lastPayoutDate     DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  payouts            Payout[]
  restaurant         Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  taxReports         TaxReport[]

  @@index([restaurantId])
  @@index([finanzamtStatus])
  @@map("restaurant_tax_profiles")
}

model TaxReport {
  id                     String                @id @default(cuid())
  driverTaxProfileId     String?
  restaurantTaxProfileId String?
  entityType             String
  type                   TaxReportType
  period                 String
  status                 TaxReportStatus       @default(PENDING)
  amount                 Float?
  taxAmount              Float?
  submittedAt            DateTime?
  confirmationNumber     String?
  pdfUrl                 String?
  xmlUrl                 String?
  errorMessage           String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  driverTaxProfile       DriverTaxProfile?     @relation(fields: [driverTaxProfileId], references: [id])
  restaurantTaxProfile   RestaurantTaxProfile? @relation(fields: [restaurantTaxProfileId], references: [id])

  @@index([driverTaxProfileId])
  @@index([restaurantTaxProfileId])
  @@index([status])
  @@index([period])
  @@map("tax_reports")
}

model Payout {
  id                     String                @id @default(cuid())
  driverTaxProfileId     String?
  restaurantTaxProfileId String?
  entityType             String
  amount                 Float
  netAmount              Float
  taxAmount              Float
  status                 PayoutStatus          @default(PENDING)
  period                 String
  taxReportId            String?
  transactionId          String?
  iban                   String?
  bic                    String?
  processedAt            DateTime?
  errorMessage           String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  driverTaxProfile       DriverTaxProfile?     @relation(fields: [driverTaxProfileId], references: [id])
  restaurantTaxProfile   RestaurantTaxProfile? @relation(fields: [restaurantTaxProfileId], references: [id])

  @@index([driverTaxProfileId])
  @@index([restaurantTaxProfileId])
  @@index([status])
  @@index([period])
  @@map("payouts")
}

model FinancialEvent {
  id        String   @id @default(cuid())
  type      String   // 'payment_completed' | 'payout_processed' | 'invoice_generated' | 'refund_processed' | 'revenue_update'
  data      Json
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([type])
  @@index([timestamp])
  @@map("financial_events")
}

model DriverSubscription {
  id                     String                  @id @default(cuid())
  driverId               String                  @unique
  tier                   SubscriptionTier        @default(BASIC)
  status                 SubscriptionStatus      @default(TRIALING)
  stripeSubscriptionId   String?                 @unique
  stripeCustomerId       String?
  stripePriceId          String?
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  cancelAtPeriodEnd      Boolean                 @default(false)
  trialEndsAt            DateTime?
  customCommissionRate   Float?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  commissionTransactions CommissionTransaction[]
  driver                 Driver                  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  contracts              SubscriptionContract[]

  @@index([driverId])
  @@index([status])
  @@index([tier])
  @@map("driver_subscriptions")
}

model CommissionTransaction {
  id                   String              @id @default(cuid())
  orderId              String              @unique
  driverId             String
  subscriptionId       String?
  orderAmount          Float
  restaurantCommission Float
  driverCommission     Float
  platformFee          Float
  tier                 SubscriptionTier
  status               CommissionStatus    @default(PENDING)
  paidAt               DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  driver               Driver              @relation(fields: [driverId], references: [id])
  order                Order               @relation(fields: [orderId], references: [id])
  subscription         DriverSubscription? @relation(fields: [subscriptionId], references: [id])

  @@index([driverId])
  @@index([orderId])
  @@index([status])
  @@index([tier])
  @@map("commission_transactions")
}

model SubscriptionTierConfig {
  id                String           @id @default(cuid())
  tier              SubscriptionTier @unique
  name              String
  price             Float
  commissionRate    Float
  displayCommission String
  features          String[]
  isPopular         Boolean          @default(false)
  deliveryLimit     Int?
  payoutThreshold   Float?
  payoutDelay       Int?
  bonusThreshold    Int?
  bonusRate         Float?
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@map("subscription_tier_configs")
}

model Admin {
  id                        String    @id @default(cuid())
  email                     String    @unique
  password                  String
  name                      String
  role                      AdminRole @default(ADMIN)
  isActive                  Boolean   @default(true)
  passwordResetToken        String?
  passwordResetTokenExpires DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  // Relations
  acknowledgedAlerts     SystemAlert[]    @relation("AlertAcknowledgedBy")
  createdIncidents       SystemIncident[] @relation("IncidentCreatedBy")
  resolvedIncidents      SystemIncident[] @relation("IncidentResolvedBy")
  fleetIncidentsResolved FleetIncident[]  @relation("FleetIncidentResolver")

  @@map("admins")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  changes   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  key         String   @id
  value       String
  category    String?
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  userType  String    @default("ADMIN")
  ipAddress String?
  userAgent String?
  expiresAt DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("sessions")
}

model TwoFactorAuth {
  id          String   @id @default(cuid())
  userId      String   @unique
  secret      String
  enabled     Boolean  @default(false)
  backupCodes String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("two_factor_auth")
}

model APIKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique
  permissions String[]  @default([])
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("api_keys")
}

model Integration {
  id          String   @id
  name        String
  type        String
  config      Json?
  isConnected Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("integrations")
}

model Webhook {
  id        String   @id @default(cuid())
  url       String
  events    String[] @default([])
  secret    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhooks")
}

model Campaign {
  id             String   @id @default(cuid())
  name           String
  type           String
  targetAudience String?
  description    String?
  status         String   @default("DRAFT")
  startDate      DateTime
  endDate        DateTime
  budget         Float    @default(0)
  metrics        Json?
