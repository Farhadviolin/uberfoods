# ============================================
# UberFoods Backend - Production Environment
# ============================================

# ==================== CORE ====================
# Node Environment (production | development | test)
NODE_ENV=production

# Server Port
PORT=3000

# ==================== DATABASE ====================
# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/uberfoods

# ==================== SECURITY ====================
# JWT Secret (MUSS stark und zufällig sein! Mindestens 32 Zeichen)
# Generiere mit: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Dev Auth Bypass (NUR für Development! In Production: false oder nicht setzen)
ALLOW_DEV_AUTH=false

# Allowed CORS Origins (komma-separiert)
# Beispiel: https://admin.uberfoods.com,https://app.uberfoods.com
ALLOWED_ORIGINS=https://admin.uberfoods.com,https://app.uberfoods.com,https://restaurant.uberfoods.com,https://driver.uberfoods.com

# ==================== LOGGING ====================
# Log Level (error | warn | info | debug | verbose)
LOG_LEVEL=info

# ==================== API DOCUMENTATION ====================
# Swagger/OpenAPI aktivieren (true | false)
# In Production normalerweise false, außer für interne Dokumentation
ENABLE_SWAGGER=false

# ==================== PAYMENT (STRIPE) ====================
# Stripe Secret Key (von Stripe Dashboard)
# Format: STRIPE_SECRET_KEY_PLACEHOLDER_... für Production, STRIPE_SECRET_KEY_PLACEHOLDER_... für Testing
STRIPE_SECRET_KEY=STRIPE_SECRET_KEY_PLACEHOLDER

# Stripe Webhook Secret (für Webhook-Validierung)
STRIPE_WEBHOOK_SECRET=STRIPE_WEBHOOK_SECRET_PLACEHOLDER

# Stripe Price IDs (für Subscription-Pläne)
STRIPE_PRICE_BASIC=price_basic_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder
STRIPE_PRICE_FULLTIME=price_fulltime_placeholder
STRIPE_PRICE_ENTERPRISE=price_enterprise_placeholder

# ==================== GOOGLE MAPS ====================
# Google Maps API Key (für Geocoding, Directions, Distance Matrix)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ==================== AWS S3 (FILE STORAGE) ====================
# AWS Access Key ID
AWS_ACCESS_KEY_ID=your_aws_access_key_id

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS Region (z.B. eu-central-1, us-east-1)
AWS_REGION=eu-central-1

# S3 Bucket Name
AWS_S3_BUCKET=uberfoods-uploads

# ==================== EMAIL (SMTP) ====================
# SMTP Host (z.B. smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=smtp.gmail.com

# SMTP Port (587 für TLS, 465 für SSL)
SMTP_PORT=587

# SMTP Username
SMTP_USER=your_smtp_username

# SMTP Password (oder App Password bei Gmail)
SMTP_PASS=your_smtp_password

# From Email Address
SMTP_FROM=noreply@uberfoods.com

# ==================== WEB PUSH NOTIFICATIONS ====================
# VAPID Public Key (für Web Push Notifications)
VAPID_PUBLIC_KEY=your_vapid_public_key

# VAPID Private Key (für Web Push Notifications)
VAPID_PRIVATE_KEY=your_vapid_private_key

# ==================== REDIS (OPTIONAL - für Caching/Queue) ====================
# Redis Connection String (optional)
# REDIS_URL=redis://localhost:6379

# ==================== MONITORING (OPTIONAL) ====================
# Sentry DSN (für Error Tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ==================== NOTES ====================
# 1. Kopiere diese Datei zu .env und fülle alle Werte aus
# 2. NIE .env Datei in Git committen!
# 3. Für Production: Verwende starke Secrets und sichere Passwörter
# 4. Generiere JWT_SECRET mit: openssl rand -base64 32
# 5. VAPID Keys generieren mit: npx web-push generate-vapid-keys
