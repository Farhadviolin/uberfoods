# ============================================
# UberFoods Backend - Environment Variables
# ============================================
# Kopiere diese Datei zu `.env` und fülle alle Werte aus.
# Für Production: Setze alle Variablen entsprechend.

# ============================================
# CORE CONFIGURATION (ERFORDERLICH)
# ============================================

# Datenbank
DATABASE_URL=postgresql://user:password@localhost:5432/uberfoods?schema=public

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:5173

# Logging
LOG_LEVEL=debug

# Swagger/API Docs
ENABLE_SWAGGER=true

# Development Auth (NUR für Development!)
ALLOW_DEV_AUTH=false

# ============================================
# PAYMENT - STRIPE (P0 - KRITISCH)
# ============================================
# Erstelle einen Stripe Account unter: https://stripe.com
# Hole deine API Keys aus dem Dashboard

# Stripe Secret Key (STRIPE_SECRET_KEY_PLACEHOLDER_... für Production, STRIPE_SECRET_KEY_PLACEHOLDER_... für Testing)
STRIPE_SECRET_KEY=STRIPE_SECRET_KEY_PLACEHOLDER

# Stripe Publishable Key (STRIPE_PUBLISHABLE_KEY_PLACEHOLDER_... für Production, STRIPE_PUBLISHABLE_KEY_PLACEHOLDER_... für Testing)
STRIPE_PUBLISHABLE_KEY=STRIPE_PUBLISHABLE_KEY_PLACEHOLDER

# Stripe Webhook Secret (für Payment-Status-Updates)
# Generiere unter: Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=STRIPE_WEBHOOK_SECRET_PLACEHOLDER

# Stripe Price IDs (für Subscription Tiers)
# Diese werden automatisch generiert durch: npm run setup:stripe-products
STRIPE_PRICE_BASIC=price_basic_your_price_id_here
STRIPE_PRICE_PRO=price_pro_your_price_id_here
STRIPE_PRICE_FULLTIME=price_fulltime_your_price_id_here
STRIPE_PRICE_ENTERPRISE=price_enterprise_your_price_id_here

# Stripe Connect (für Restaurant/Driver Payouts - Optional)
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id
STRIPE_CONNECT_REFRESH_URL=https://your-frontend/connect/refresh
STRIPE_CONNECT_RETURN_URL=https://your-frontend/connect/return

# ============================================
# GOOGLE MAPS API (P0 - KRITISCH)
# ============================================
# Erstelle ein Google Cloud Project unter: https://console.cloud.google.com
# Aktiviere: Maps JavaScript API, Directions API, Geocoding API, Distance Matrix API
# Generiere einen API Key mit entsprechenden Restrictions

GOOGLE_MAPS_API_KEY=AIzaSyYourGoogleMapsAPIKeyHere

# ============================================
# TRAFFIC APIs (P1 - OPTIONAL, aber empfohlen)
# ============================================
# Option 1: TomTom Traffic API (Empfohlen für Traffic Incidents)
# Erstelle Account unter: https://developer.tomtom.com
# Aktiviere: Traffic Flow API, Traffic Incidents API
TOMTOM_API_KEY=your_tomtom_api_key_here

# Option 2: HERE Traffic API (Alternative)
# Erstelle Account unter: https://developer.here.com
# Aktiviere: Traffic API
HERE_API_KEY=your_here_api_key_here
HERE_APP_ID=your_here_app_id
HERE_APP_CODE=your_here_app_code

# ============================================
# EMAIL SERVICE (P0 - KRITISCH)
# ============================================
# Option 1: SendGrid (Empfohlen)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@uberfoods.com
SENDGRID_FROM_NAME=UberFoods

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Option 2: AWS SES (Alternative)
# AWS_SES_REGION=eu-central-1
# AWS_SES_ACCESS_KEY_ID=your_aws_access_key
# AWS_SES_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_SES_FROM_EMAIL=noreply@uberfoods.com

# Option 3: SMTP (Alternative)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=noreply@uberfoods.com
# SMTP_FROM_NAME=UberFoods

# ============================================
# CLOUD STORAGE - AWS S3 (P1 - WICHTIG)
# ============================================
# Erstelle einen AWS Account und S3 Bucket
# Generiere IAM Access Keys mit S3 Permissions

AWS_S3_BUCKET=uberfoods-uploads
AWS_S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# CloudFront CDN (Optional, aber empfohlen für Performance)
AWS_CLOUDFRONT_URL=https://cdn.uberfoods.com

# Alternative: Google Cloud Storage
# GCS_BUCKET_NAME=uberfoods-uploads
# GCS_PROJECT_ID=your-gcp-project-id
# GCS_KEY_FILE=path/to/service-account-key.json

# Google Cloud Vision (OCR)
GCV_PROJECT_ID=your_gcp_project_id
GCV_KEY_FILE=path/to/gcv-service-account.json

# ============================================
# PUSH NOTIFICATIONS (P1 - WICHTIG)
# ============================================
# Generiere VAPID Keys mit: npm install -g web-push && web-push generate-vapid-keys

VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@uberfoods.com
VAPID_SUBJECT=mailto:admin@uberfoods.com

# ============================================
# SOCIAL AUTH (P1 - WICHTIG)
# ============================================
# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id_here

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Apple Sign In
APPLE_CLIENT_ID=your_apple_client_id_here
APPLE_TEAM_ID=your_apple_team_id_here
APPLE_KEY_ID=your_apple_key_id_here
APPLE_PRIVATE_KEY=your_apple_private_key_here

# Firebase Cloud Messaging (Optional, für Mobile Apps)
# FIREBASE_SERVER_KEY=your_firebase_server_key
# FIREBASE_PROJECT_ID=your_firebase_project_id

# ============================================
# ERROR TRACKING & MONITORING (P1 - WICHTIG)
# ============================================
# Erstelle ein Sentry Account unter: https://sentry.io

SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Alternative: LogRocket
# LOGROCKET_APP_ID=your_logrocket_app_id

# ============================================
# ANALYTICS (P2 - OPTIONAL)
# ============================================
# Google Analytics (Optional)
# GA_TRACKING_ID=G-XXXXXXXXXX

# ============================================
# SECURITY
# ============================================

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=*

# ============================================
# FEATURE FLAGS (Optional)
# ============================================

# Enable/Disable Features
ENABLE_ML_FEATURES=true
ENABLE_SOCIAL_FEATURES=true
ENABLE_GAMIFICATION=true
ENABLE_ANALYTICS=true

# ============================================
# EXTERNAL SERVICES (Optional)
# ============================================

# Weather API (für Predictive Features)
# OPENWEATHER_API_KEY=your_openweather_api_key

# Traffic API (für Route Optimization)
# TOMTOM_API_KEY=your_tomtom_api_key

# ============================================
# NOTES
# ============================================
# 1. ÄNDERE ALLE PLACEHOLDER-WERTE!
# 2. Verwende NIE Production-Keys in Development
# 3. Nutze Environment-Management (z.B. AWS Secrets Manager, HashiCorp Vault)
# 4. Rotiere regelmäßig API Keys
# 5. Setze entsprechende CORS/API Restrictions in den Service-Dashboards

