{
  "name": "UberFood-food-backend",
  "version": "1.0.0",
  "description": "Backend für UberFoods Delivery Platform",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:e2e": "tsc -p tsconfig.build.e2e.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "TS_NODE_TRANSPILE_ONLY=true nest start",
    "start:dev": "nest start --watch --tsConfig tsconfig.build.json",
    "start:full": "TS_NODE_TRANSPILE_ONLY=true nest start --entryFile main.full",
    "start:full:watch": "TS_NODE_TRANSPILE_ONLY=true nest start --watch --entryFile main.full",
    "start:e2e": "node ../scripts/start-backend-e2e.mjs",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.prod.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:backend": "jest --runInBand",
    "test:backend:detect-open-handles": "jest --runInBand --detectOpenHandles --verbose --testLocationInResults",
    "test:ci": "jest --runInBand --detectOpenHandles --verbose --testLocationInResults",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:api": "pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/final-verification.ps1",
    "test:api:smoke": "pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-driver.ps1",
    "test:api:quick": "pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/quick-test.ps1",
    "smoke:mvp": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ../scripts/smoke-mvp.ps1",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:integration": "node scripts/test-full-subscription-integration.js",
    "test:integration:ci": "node scripts/test-full-subscription-integration.js",
    "test:frontend-backend": "jest --config ./test/jest-e2e.json --testPathPattern=frontend-backend",
    "openapi:generate": "ts-node scripts/generate-openapi.ts",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema=./prisma/schema.prisma",
    "prisma:reset": "prisma migrate reset --force --schema=./prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./prisma/schema.prisma",
    "prisma:generate:abs": "prisma generate --schema=\"$PWD/prisma/schema.prisma\"",
    "prisma:deploy:abs": "prisma migrate deploy --schema=\"$PWD/prisma/schema.prisma\"",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed-admin": "ts-node prisma/seed-admin.ts",
    "prisma:seed-rbac": "node prisma/seed-rbac.js",
    "prisma:seed-tier-configs": "ts-node prisma/seed-tier-configs.ts",
    "migrate:drivers": "ts-node scripts/migrate-drivers-to-subscriptions.ts",
    "test:webhooks": "ts-node scripts/test-webhooks.ts",
    "test:emails": "ts-node scripts/test-subscription-emails.ts",
    "test:email-templates": "node scripts/test-email-templates.js",
    "test:payment-failure": "node scripts/test-payment-failure-recovery.js",
    "setup:production": "ts-node scripts/setup-production-subscriptions.ts",
    "setup:check": "node scripts/setup-check.js",
    "setup:validate-env": "node scripts/validate-env.js",
    "setup:generate-vapid": "node scripts/generate-vapid-keys.js",
    "setup:check-services": "bash scripts/check-services.sh",
    "check:connection": "node scripts/check-connection.js",
    "check:db": "npx prisma validate && npx prisma db pull --force",
    "check:all": "npm run check:db && npm run check:connection",
    "seed:performance": "ts-node scripts/seed-performance-orders.ts",
    "test:pagination": "ts-node scripts/test-pagination-performance.ts",
    "test:websocket": "ts-node scripts/test-websocket-load.ts",
    "test:k6": "docker-compose -f docker-compose.k6.yml up --abort-on-container-exit",
    "benchmark:baseline": "node scripts/benchmark-baseline.js",
    "benchmark:regression": "node scripts/benchmark-baseline.js regression",
    "benchmark:report": "node scripts/benchmark-baseline.js list"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.931.0",
    "@aws-sdk/lib-storage": "^3.931.0",
    "@google-cloud/vision": "^4.0.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.24",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^5.0.0",
    "@prisma/config": "^7.1.0",
    "@sentry/node": "^10.25.0",
    "@sentry/profiling-node": "^10.25.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/stripe": "^8.0.416",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "class-sanitizer": "^1.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "firebase-admin": "^13.6.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "json2csv": "^5.0.7",
    "ml-regression": "^6.3.0",
    "multer": "^2.1.1",
    "nest-winston": "^1.10.2",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.10",
    "opossum": "^9.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.15.2",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.34.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.1.13",
    "redis": "^4.7.1",
    "rxjs": "^7.8.1",
    "simple-statistics": "^7.8.8",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "stripe": "^19.3.1",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.0.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.24",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.13.9",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "prisma": "^5.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  },
  "overrides": {
    "glob": "^8.1.0",
    "inflight": "^1.0.6",
    "exceljs": {
      "uuid": "^11.1.1"
    },
    "@google-cloud/storage": {
      "uuid": "^11.1.1"
    },
    "gaxios": {
      "uuid": "^11.1.1"
    },
    "google-gax": {
      "uuid": "^11.1.1"
    },
    "teeny-request": {
      "uuid": "^11.1.1"
    }
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "esModuleInterop": true,
            "allowSyntheticDefaultImports": true
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ],
    "moduleNameMapper": {
      "^uuid$": "uuid",
      "^@/(.*)$": "<rootDir>/../src/$1"
    }
  }
}
