# ============================================
# UberFoods Backend - Production Environment
# ============================================
# Kopiere diese Datei zu .env und fülle alle Werte aus.
# NIE echte Secrets committen!

# ============================================
# REQUIRED - Production wird ohne diese Werte nicht starten
# ============================================

# Database
DATABASE_URL=postgresql://uberfoods_user:YOUR_DB_PASSWORD@postgres:5432/uberfoods_production

# JWT Secrets (generiere neue für Production)
JWT_SECRET=your-production-jwt-secret-key-here
JWT_REFRESH_SECRET=your-production-refresh-secret-key-here

# Seed Passwords (für database seeding)
SEED_ADMIN_PASSWORD=your-production-admin-password-here
SEED_CUSTOMER_PASSWORD=your-production-customer-password-here
SEED_RESTAURANT_PASSWORD=your-production-restaurant-password-here
SEED_DRIVER_PASSWORD=your-production-driver-password-here

# Default Driver Password (für AuthService fallback)
DEFAULT_DRIVER_PASSWORD=your-production-default-driver-password-here

# Stripe (Production Keys)
STRIPE_SECRET_KEY=STRIPE_SECRET_KEY_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=STRIPE_WEBHOOK_SECRET_PLACEHOLDER
STRIPE_PUBLISHABLE_KEY=STRIPE_PUBLISHABLE_KEY_PLACEHOLDER

# PayPal (Production Keys)
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# ============================================
# CORS - KRITISCH für Production
# ============================================
# Komma-separierte Liste deiner Production-Domains
# ERFORDERLICH in Production - App startet nicht ohne diese Variable
ALLOWED_ORIGINS=https://customer.yourdomain.com,https://admin.yourdomain.com,https://restaurant.yourdomain.com,https://driver.yourdomain.com

# ============================================
# RECOMMENDED - Verbessere Production-Readiness
# ============================================

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=your_redis_password_here

# Email Services
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@uberfoods.com
SENDGRID_FROM_NAME=UberFoods
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@uberfoods.com
SMTP_FROM_NAME=UberFoods

# SMS Service
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# External APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Monitoring
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Payment Methods
APPLE_MERCHANT_ID=merchant.yourdomain
GOOGLE_PAY_MERCHANT_ID=your_google_pay_merchant_id

# ============================================
# OPTIONAL - Für erweiterte Features
# ============================================

# Analytics
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID

# AI/ML Features (falls verwendet)
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# NOTES
# ============================================
# 1. ÄNDERE ALLE PLATZHALTER!
# 2. Verwende starke, einzigartige Secrets
# 3. Setze ALLOWED_ORIGINS korrekt für deine Domains
# 4. Teste alle Services vor dem Deployment
