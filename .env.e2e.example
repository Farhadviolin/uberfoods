# E2E Environment Configuration
# Copy this file to backend/.env.e2e and adjust values as needed

# Database - Points to Docker E2E Postgres
DATABASE_URL=postgresql://uberfoods:uberfoods@localhost:5433/uberfoods_e2e

# Application
NODE_ENV=e2e
PORT=3000

# JWT
JWT_SECRET=e2e-jwt-secret-key-for-testing-only-not-for-production

# Redis (if used)
REDIS_URL=redis://localhost:6379

# Admin Test Credentials
TEST_ADMIN_EMAIL=admin@uberfoods.com
TEST_ADMIN_PASSWORD=admin123

# E2E Test Credentials (alternative naming)
E2E_ADMIN_EMAIL=admin@uberfoods.com
E2E_ADMIN_PASSWORD=admin123

# Email (disabled for E2E)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Stripe (test keys for E2E)
STRIPE_SECRET_KEY=STRIPE_SECRET_KEY_PLACEHOLDER
STRIPE_PUBLISHABLE_KEY=STRIPE_PUBLISHABLE_KEY_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=STRIPE_WEBHOOK_SECRET_PLACEHOLDER
STRIPE_PRICE_BASIC=price_basic_e2e
STRIPE_PRICE_PRO=price_pro_e2e
STRIPE_PRICE_FULLTIME=price_fulltime_e2e
STRIPE_PRICE_ENTERPRISE=price_enterprise_e2e

# Logging
LOG_LEVEL=debug

# Feature Flags (E2E specific)
FEATURE_DUAL_PUBLISH=false
WRITE_GUARD_ENABLED=false
