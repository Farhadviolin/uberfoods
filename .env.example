# UberFoods root environment template

# Shared runtime
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres123@localhost:5434/uberfoods
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-development
JWT_REFRESH_SECRET=change-me-in-development-refresh
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:5173

# Optional security / monitoring
ENABLE_SWAGGER=true
SENTRY_DSN=
APP_VERSION=1.0.0

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_FULLTIME=
STRIPE_PRICE_ENTERPRISE=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Web push
VAPID_SUBJECT=mailto:ops@uberfoods.local
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Messaging / comms
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@uberfoods.local
SMTP_FROM_NAME=UberFoods
SMS_PROVIDER=

# Frontend URLs
FRONTEND_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002
RESTAURANT_URL=http://localhost:3003
DRIVER_URL=http://localhost:3004

# Seed / local test toggles
SEED_ALLOW_DEFAULTS=true
SEED_CUSTOMER_PASSWORD=customer123
SEED_RESTAURANT_PASSWORD=restaurant123
SEED_DRIVER_PASSWORD=driver123
ALLOW_DEV_AUTH=false
