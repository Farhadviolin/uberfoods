{
  "dashboard": {
    "id": null,
    "title": "Enterprise Sync - Performance Monitoring",
    "tags": ["enterprise-sync", "performance", "monitoring"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "CPU Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "enterprise_sync_cpu_usage",
            "legendFormat": "CPU %"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 70, "color": "yellow" },
                { "value": 90, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Memory Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "enterprise_sync_memory_usage",
            "legendFormat": "Memory %"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 70, "color": "yellow" },
                { "value": 90, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Response Time",
        "type": "timeseries",
        "targets": [
          {
            "expr": "enterprise_sync_response_time",
            "legendFormat": "Response Time (ms)"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 200, "color": "yellow" },
                { "value": 500, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Error Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "enterprise_sync_error_rate",
            "legendFormat": "Error Rate %"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1, "color": "yellow" },
                { "value": 5, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Throughput",
        "type": "timeseries",
        "targets": [
          {
            "expr": "enterprise_sync_throughput",
            "legendFormat": "Requests/sec"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        },
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 6,
        "title": "System Health Status",
        "type": "stat",
        "targets": [
          {
            "expr": "enterprise_sync_system_health",
            "legendFormat": "{{status}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 16
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "options": { "0": { "text": "CRITICAL", "color": "red" } } },
              { "options": { "1": { "text": "UNHEALTHY", "color": "orange" } } },
              { "options": { "2": { "text": "DEGRADED", "color": "yellow" } } },
              { "options": { "3": { "text": "HEALTHY", "color": "green" } } }
            ]
          }
        }
      },
      {
        "id": 7,
        "title": "Service Status",
        "type": "table",
        "targets": [
          {
            "expr": "enterprise_sync_service_status",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 24
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true
              },
              "indexByName": {
                "service": 0,
                "status": 1,
                "responseTime": 2,
                "errorRate": 3
              },
              "renameByName": {
                "service": "Service",
                "status": "Status",
                "responseTime": "Response Time (ms)",
                "errorRate": "Error Rate (%)"
              }
            }
          }
        ]
      },
      {
        "id": 8,
        "title": "Notification Events by Type",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum by (type) (enterprise_sync_notifications_total)",
            "legendFormat": "{{type}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 32
        }
      },
      {
        "id": 9,
        "title": "Financial Events Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(enterprise_sync_financial_events_total[5m])",
            "legendFormat": "{{type}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 32
        }
      },
      {
        "id": 10,
        "title": "Security Events by Severity",
        "type": "bargauge",
        "targets": [
          {
            "expr": "sum by (severity) (enterprise_sync_security_events_total)",
            "legendFormat": "{{severity}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 40
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "mappings": [
              { "options": { "critical": { "color": "red" } } },
              { "options": { "high": { "color": "orange" } } },
              { "options": { "medium": { "color": "yellow" } } },
              { "options": { "low": { "color": "green" } } }
            ]
          }
        }
      },
      {
        "id": 11,
        "title": "ML Predictions Accuracy",
        "type": "timeseries",
        "targets": [
          {
            "expr": "enterprise_sync_ml_prediction_accuracy",
            "legendFormat": "{{type}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 40
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "schemaVersion": 27,
    "version": 1
  }
}

